<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Online Market</title>
    <link rel="stylesheet" href="1.css">
</head>
<body>

    <header>
        <div class="logo">Online<span>Market</span></div>
        <nav>
            <ul>
                <li><a href="#">Birinshi bolim</a></li>
                <li><a href="#">Onimler</a></li>
                <li><a href="#">Sebet (0)</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <h2>Biznin onimler</h2>
        
        <div class="product-grid">
