                <button class="buy-btn">Sevetke qosiw</button>
            </div>

            <div class="product-card">
                <div class="product-image">📱</div>
                <h3>Smartphone X</h3>
                <p>Baxasi: 8,500,000 so'm</p>
                <button class="buy-btn">Sebetke qosiw</button>
            </div>

            <div class="product-card">
                <div class="product-image">🎧</div>
                <h3>Wireless Headphones</h3>
                <p>Baxasi: 1,200,000 so'm</p>
                <button class="buy-btn">Sevetke qosiw</button>
            </div>

            <div class="product-card">
                <div class="product-image">⌚</div>
                <h3>Smart Watch</h3>
                <p>Baxasi: 2,000,000 so'm</p>
                <button class="buy-btn">Sevetke qosiw</button>
            </div>
        </div>
    </main>

    <footer>
        <p>&copy; 2026 Mini Online Market. Hamme huquqlardan qorgangan halda.</p>
    </footer>

</body>
</html>
